<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.GameVault" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/void_black</item>
        <item name="colorOnPrimary">@color/pure_white</item>

        <item name="colorSecondary">@color/void_black</item>
        <item name="colorOnSecondary">@color/pure_white</item>

        <item name="android:windowBackground">@color/pure_white</item>
        <item name="colorSurface">@color/surface_light</item>
        <item name="colorOnSurface">@color/void_black</item>

        <item name="android:statusBarColor">@color/void_black</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">@color/pure_white</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="O_MR1">true</item>

        <item name="colorError">@color/neon_red</item>
        <item name="colorOnError">@color/pure_white</item>

        <item name="android:fontFamily">@font/neo_sans_std_medium</item>
        <item name="android:textColor">@color/surface_dark</item>



    </style>

    <style name="Theme.GameVault.Fullscreen">
        <item name="android:windowFullscreen">true</item>
    </style>
</resources>