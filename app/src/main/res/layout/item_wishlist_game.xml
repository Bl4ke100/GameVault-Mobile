<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="150dp"
    android:layout_height="170dp"
    android:layout_margin="5dp"
    android:clipChildren="false"
    android:clipToPadding="false"
    app:cardCornerRadius="12dp"
    app:cardElevation="6dp">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Poster Image -->
        <ImageView
            android:id="@+id/favGameImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop" />

        <!-- Top gradient -->
        <View
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_gravity="top"
            android:background="@drawable/gradient_top_scrim" />

        <!-- Bottom gradient -->
        <View
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_gravity="bottom"
            android:background="@drawable/gradient_bottom_scrim" />

        <!-- Game Title - top start -->
        <TextView
            android:id="@+id/favGameTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="top"
            android:layout_marginTop="8dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:paddingHorizontal="10dp"
            android:shadowColor="#99000000"
            android:shadowDx="0"
            android:shadowDy="1"
            android:shadowRadius="4"
            android:text="Game Title"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold" />

        <!-- Remove Button - top end -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnRemoveFav"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_gravity="top|end"
            android:layout_margin="8dp"
            app:cardBackgroundColor="?attr/colorOnPrimary"
            app:cardCornerRadius="15dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="center"
                android:src="@drawable/favorite_solid"
                app:tint="?attr/colorPrimary" />

        </com.google.android.material.card.MaterialCardView>

        <!-- Price Badge - bottom end -->
        <TextView
            android:id="@+id/favGamePrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_margin="8dp"
            android:background="@drawable/bg_price_badge"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:text="LKR 0.00"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:textStyle="bold" />

    </FrameLayout>

</com.google.android.material.card.MaterialCardView>